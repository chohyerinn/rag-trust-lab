# CLOVA Studio API credentials — required for live generation and embedding.
# Either variable works; the code checks CLOVASTUDIO_API_KEY first, then CLOVA_API_KEY.
CLOVASTUDIO_API_KEY=
CLOVA_API_KEY=

# Endpoint and model settings (defaults shown — override only if needed).
CLOVA_BASE_URL=https://clovastudio.stream.ntruss.com/v1/openai
CLOVA_MODEL=HCX-005
CLOVA_EMBED_MODEL=bge-m3

# Generation parameters.
CLOVA_TEMPERATURE=0
CLOVA_MAX_TOKENS=512
CLOVA_TIMEOUT=120
