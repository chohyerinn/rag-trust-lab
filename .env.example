# Copy this file to .env for local runs, then fill one of the keys below.
# .env is ignored by Git because it may contain real secrets.
CLOVASTUDIO_API_KEY=
CLOVA_API_KEY=

# LiteLLM path. OPENAI_API_KEY enables the default gpt-4o-mini example.
# For other providers, set the provider key expected by LiteLLM and change
# LITELLM_MODEL / LITELLM_JUDGE_MODEL, e.g. anthropic/claude-haiku-4-5-20251001.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LITELLM_MODEL=gpt-4o-mini
LITELLM_JUDGE_MODEL=gpt-4o-mini

# Claude example:
# LITELLM_MODEL=anthropic/claude-haiku-4-5-20251001
# LITELLM_JUDGE_MODEL=anthropic/claude-haiku-4-5-20251001

# Optional overrides. The app uses these defaults if they are omitted.
CLOVA_BASE_URL=https://clovastudio.stream.ntruss.com/v1/openai
CLOVA_MODEL=HCX-005
CLOVA_EMBED_MODEL=bge-m3

CLOVA_TEMPERATURE=0
CLOVA_MAX_TOKENS=512
CLOVA_TIMEOUT=120
